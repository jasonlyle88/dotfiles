[core]
	excludesfile = ~/.config/git/ignore
[pull]
    rebase = false
[fetch]
    prune = true
[pager]
    branch = false
    tag = false
    log = false
[diff]
    tool = bc
[merge]
    tool = bc
[mergetool "bc"]
    trustExitCode = true

