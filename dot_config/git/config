[user]
    email = jason.lyle88@gmail.com
    name = Jason Lyle
    signingkey = ~/.ssh/personal-github-sign-20260611-prv.key
[core]
    excludesfile = ~/.config/git/ignore
[init]
    defaultBranch = main
[fetch]
    prune = true
[pull]
    rebase = false
[push]
    autoSetupRemote = true
[gpg]
    format = ssh
[commit]
    gpgsign = true
[pager]
    branch = false
    tag = false
    log = false
[diff]
    tool = bc
[merge]
    tool = bc
[mergetool "bc"]
    trustExitCode = true

#
# Add a work override
#
[includeIf "gitdir:~/Work/xgbu-ace/"]
    path = ~/.config/git/config_xgbu-ace
